# ─────────────────────────────────────────────
# Biogenie — Moniteur GTC · Configuration
# ─────────────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs

# ── ALERTES SMS (Twilio) ──────────────────────
# Crée un compte sur twilio.com (gratuit pour tester)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15145550000
ALERT_PHONE_NUMBER=+15145551234   # téléphone du commercial Biogenie

# ── ALERTES EMAIL (Gmail) ─────────────────────
# Utilise un "App Password" Gmail (pas ton vrai mot de passe)
# → myaccount.google.com/apppasswords
SMTP_USER=toncompte@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
ALERT_EMAIL=commercial@biogenie.ca
